# Application
APP_ENV=development
LOG_LEVEL=info

# Crawler identity
CRAWLER_USER_AGENT=image-crawler-system/0.1

# Crawl behavior
CRAWL_START_URLS=https://example.com
CRAWL_MAX_CONCURRENCY=4
CRAWL_REQUEST_TIMEOUT_SECONDS=30
CRAWL_RETRY_ATTEMPTS=3
CRAWL_RATE_LIMIT_PER_SECOND=1
CRAWL_RESPECT_ROBOTS_TXT=true

# Storage
DATABASE_URL=sqlite:///data/image-crawler-system.db
IMAGE_STORAGE_PATH=./data/images

# Optional integrations
HTTP_PROXY=
HTTPS_PROXY=
